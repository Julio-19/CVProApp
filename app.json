{
  "expo": {
    "name": "CVProApp",
    "slug": "CVProApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cvproapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.votrecompany.cvpro",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Autoriser CVPro à accéder à vos photos pour votre CV",
        "NSCameraUsageDescription": "Autoriser CVPro à utiliser la caméra pour votre photo de CV"
      }
    },
    "android": {
      "package": "com.votrecompany.cvpro",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#534AB7",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoriser CVPro à accéder à vos photos pour votre CV",
          "cameraPermission": "Autoriser CVPro à utiliser la caméra pour votre photo de CV"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cff2dbb4-c251-4b9b-b175-2f470f18bc40"
      }
    }
  }
}
