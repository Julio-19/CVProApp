{
  "expo": {
    "name": "CVProApp",
    "slug": "CVProApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cvproapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.votrecompany.cvpro",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Autoriser CVPro à accéder à vos photos pour votre CV",
        "NSCameraUsageDescription": "Autoriser CVPro à utiliser la caméra pour votre photo de CV"
      }
    },
    "android": {
      "package": "com.votrecompany.cvpro",
      "adaptiveIcon": {
        "backgroundColor": "#534AB7",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#534AB7",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoriser CVPro à accéder à vos photos",
          "cameraPermission": "Autoriser CVPro à utiliser la caméra"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#534AB7"
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}